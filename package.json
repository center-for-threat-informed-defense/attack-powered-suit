{
  "name": "svelte-app",
  "version": "1.11.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest --config ./jest.config.mjs",
    "watch-test": "jest --collect-coverage --watch --config ./jest.config.mjs",
    "start": "sirv public --no-clear",
    "fetch-attack": "node scripts/fetch-attack.js",
    "build-index": "node scripts/build-index.js",
    "version": "node scripts/version.js"
  },
  "config": {
    "message": "Bump version to %s"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@rollup/plugin-commonjs": "^17.0.0",
    "@rollup/plugin-node-resolve": "^11.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "babel-jest": "^30.3.0",
    "lunr": "^2.3.9",
    "rollup": "^2.80.0",
    "rollup-plugin-css-only": "^3.1.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^3.59.2",
    "svelte-jester": "^3.0.0",
    "whatwg-fetch": "^3.6.20"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "marked": "^4.3.0",
    "rollup-plugin-copy": "^3.5.0",
    "sanitize-html": "^2.17.2",
    "sirv-cli": "^2.0.2"
  },
  "overrides": {
    "terser": ">=5.14.2 <6",
    "ws": "^7.5.10",
    "tough-cookie": "^4.1.3",
    "word-wrap": "^1.2.4",
    "brace-expansion": ">=1.1.12 <2",
    "braces": ">=3.0.3 <4",
    "micromatch": ">=4.0.8 <5",
    "nanoid": ">=3.3.8 <4",
    "@babel/traverse": ">=7.23.2 <8",
    "@babel/runtime": ">=7.26.10 <8",
    "@babel/helpers": ">=7.26.10 <8",
    "@tootallnate/once": "^3.0.1"
  },
  "//": "NOTE: Keep the pre-commit list in sync with the Makefile pre-commit-run target.",
  "pre-commit": [
    "test"
  ]
